{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, organization_id, event_id, actor_id, action, resource_type,\n                   resource_id, metadata, correlation_id, occurred_at\n            FROM audit_log\n            WHERE organization_id = $1\n              AND ($2::uuid IS NULL OR id < $2)\n            ORDER BY id DESC\n            LIMIT $3\n            ",
