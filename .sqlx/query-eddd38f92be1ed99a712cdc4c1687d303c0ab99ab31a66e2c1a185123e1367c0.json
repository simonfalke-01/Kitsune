  "query": "\n            SELECT u.id,u.organization_id,u.display_name,u.email_normalized,u.email_verified\n            FROM users u\n            JOIN organizations o ON o.id = u.organization_id\n            WHERE o.slug = $1 AND u.email_normalized = $2 AND u.disabled = false\n            ",
