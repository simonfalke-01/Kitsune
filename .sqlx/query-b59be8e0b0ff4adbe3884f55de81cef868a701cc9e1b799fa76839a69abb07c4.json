  "query": "\n            SELECT id,event_id,created_by,data,priority,created_at,expires_at,retracted_at\n            FROM notifications\n            WHERE organization_id = $1 AND template = 'announcement'\n            ORDER BY created_at DESC,id DESC\n            LIMIT $2\n            ",
