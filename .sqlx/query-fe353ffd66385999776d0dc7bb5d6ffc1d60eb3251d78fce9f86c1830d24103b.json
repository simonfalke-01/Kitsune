  "query": "\n            SELECT b.id,b.event_id,b.name,b.advancement_slots\n            FROM brackets b\n            JOIN events e ON e.id = b.event_id\n            WHERE b.event_id = $1 AND e.organization_id = $2\n            ORDER BY b.name,b.id\n            ",
