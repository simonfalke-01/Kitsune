  "query": "\n            SELECT d.id,d.event_id,d.name,d.position\n            FROM divisions d\n            JOIN events e ON e.id = d.event_id\n            WHERE d.event_id = $1 AND e.organization_id = $2\n            ORDER BY d.position,d.name,d.id\n            ",
