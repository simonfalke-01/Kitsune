{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT t.id AS team_id,t.name AS team_name,tm.captain,tm.joined_at\n            FROM team_members tm\n            JOIN teams t ON t.id = tm.team_id\n            WHERE tm.user_id = $1 AND t.organization_id = $2\n            ORDER BY t.name,t.id\n            ",
