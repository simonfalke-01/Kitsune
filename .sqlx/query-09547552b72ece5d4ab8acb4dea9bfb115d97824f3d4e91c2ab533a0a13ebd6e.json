  "query": "\n            SELECT t.id,t.name,t.created_at\n            FROM teams t\n            JOIN team_members mine ON mine.team_id = t.id\n            WHERE t.organization_id = $1 AND mine.user_id = $2\n            ORDER BY t.name,t.id\n            ",
