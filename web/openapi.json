{
  "components": {
    "schemas": {
      "ErrorBody": {
        "description": "Machine-readable error response.",
        "properties": {
          "code": {
            "description": "Stable error code.",
            "type": "string"
          },
          "message": {
            "description": "Safe human-readable detail.",
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "type": "object"
      },
      "HealthResponse": {
        "description": "Health document.",
        "properties": {
          "status": {
            "description": "Stable status.",
            "type": "string"
          },
          "uptime_seconds": {
            "description": "Process uptime in seconds.",
            "format": "int64",
            "minimum": 0,
            "type": "integer"
          },
          "version": {
            "description": "Server version.",
            "type": "string"
          }
        },
        "required": [
          "status",
          "version",
          "uptime_seconds"
        ],
        "type": "object"
      },
      "LoginRequest": {
        "description": "Local login input.",
        "properties": {
          "email": {
            "description": "Account email.",
            "type": "string"
          },
          "organization": {
            "description": "Organization slug.",
            "type": "string"
          },
          "password": {
            "description": "Account password.",
            "format": "password",
            "type": "string"
          }
        },
        "required": [
          "organization",
          "email",
          "password"
        ],
        "type": "object"
      },
      "ReadinessResponse": {
        "description": "Readiness document.",
        "properties": {
          "postgres": {
            "description": "PostgreSQL dependency state.",
            "type": "string"
          },
          "status": {
            "description": "Stable status.",
            "type": "string"
          }
        },
        "required": [
          "status",
          "postgres"
        ],
        "type": "object"
      },
      "SessionResponse": {
        "description": "Session bootstrap used by the Svelte client.",
        "properties": {
          "csrf_token": {
            "description": "CSRF value required in `x-csrf-token` on mutations.",
            "type": "string"
          },
          "expires_at": {
            "description": "Session expiry.",
            "format": "date-time",
            "type": "string"
          },
          "permissions": {
            "description": "Applicable permission keys.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "user": {
            "$ref": "#/components/schemas/UserResponse",
            "description": "Current account."
          }
        },
        "required": [
          "user",
          "csrf_token",
          "permissions",
          "expires_at"
        ],
        "type": "object"
      },
      "SetupRequest": {
        "description": "First organization and administrator input.",
        "properties": {
          "display_name": {
            "description": "Administrator display name.",
            "type": "string"
          },
          "email": {
            "description": "Administrator email.",
            "type": "string"
          },
          "organization_name": {
            "description": "Organization display name.",
            "type": "string"
          },
          "organization_slug": {
            "description": "URL-safe organization key.",
            "type": "string"
          },
          "password": {
            "description": "Administrator password (12–128 characters).",
            "format": "password",
            "type": "string"
          }
        },
        "required": [
          "organization_name",
          "organization_slug",
          "display_name",
          "email",
          "password"
        ],
        "type": "object"
      },
      "SetupStatusResponse": {
        "description": "First-run state.",
        "properties": {
          "required": {
            "description": "True when no user exists and setup can be completed.",
            "type": "boolean"
          }
        },
        "required": [
          "required"
        ],
        "type": "object"
      },
      "UserResponse": {
        "description": "Safe account projection.",
        "properties": {
          "display_name": {
            "description": "Display name.",
            "type": "string"
          },
          "email": {
            "description": "Normalized email.",
            "type": "string"
          },
          "email_verified": {
            "description": "Email ownership state.",
            "type": "boolean"
          },
          "id": {
            "description": "User ID.",
            "format": "uuid",
            "type": "string"
          },
          "organization_id": {
            "description": "Organization ID.",
            "format": "uuid",
            "type": "string"
          }
        },
        "required": [
          "id",
          "organization_id",
          "display_name",
          "email",
          "email_verified"
        ],
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Typed organizer, player, integration, and realtime API",
    "license": {
      "identifier": "LicenseRef-KCL-1.0",
      "name": "LicenseRef-KCL-1.0"
    },
    "title": "Kitsune API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/auth/login": {
      "post": {
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              }
            },
            "description": ""
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            },
            "description": ""
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            },
            "description": ""
          }
        },
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "operationId": "logout",
        "responses": {
          "204": {
            "description": ""
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            },
            "description": ""
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            },
            "description": ""
          }
        },
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/auth/session": {
      "get": {
        "operationId": "current_session",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              }
            },
            "description": ""
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            },
            "description": ""
          }
        },
        "tags": [
          "auth"
        ]
      }
    },
    "/api/v1/setup": {
      "get": {
        "operationId": "setup_status",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SetupStatusResponse"
                }
              }
            },
            "description": ""
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            },
            "description": ""
          }
        },
        "tags": [
          "auth"
        ]
      },
      "post": {
        "operationId": "setup",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetupRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              }
            },
            "description": ""
          },
          "409": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            },
            "description": ""
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            },
            "description": ""
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            },
            "description": ""
          }
        },
        "tags": [
          "auth"
        ]
      }
    },
    "/health": {
      "get": {
        "operationId": "health",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": ""
          }
        },
        "tags": [
          "system"
        ]
      }
    },
    "/ready": {
      "get": {
        "operationId": "readiness",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadinessResponse"
                }
              }
            },
            "description": ""
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorBody"
                }
              }
            },
            "description": ""
          }
        },
        "tags": [
          "system"
        ]
      }
    }
  },
  "tags": [
    {
      "description": "Health and diagnostics",
      "name": "system"
    },
    {
      "description": "Setup, sessions, and authentication",
      "name": "auth"
    }
  ]
}