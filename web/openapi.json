{
  "components": {
    "schemas": {
      "ErrorBody": {
        "description": "Machine-readable error response.",
        "properties": {
          "code": {
            "description": "Stable error code.",
            "type": "string"
          },
          "message": {
            "description": "Safe human-readable detail.",
            "type": "string"
          }
        },
        "required": [
          "code",
          "message"
        ],
        "type": "object"
      },
      "HealthResponse": {
        "description": "Health document.",
        "properties": {
          "status": {
            "description": "Stable status.",
            "type": "string"
          },
          "uptime_seconds": {
            "description": "Process uptime in seconds.",
            "format": "int64",
            "minimum": 0,
            "type": "integer"
          },
          "version": {
            "description": "Server version.",
            "type": "string"
          }
        },
        "required": [
          "status",
          "version",
          "uptime_seconds"
        ],
        "type": "object"
      },
      "LoginRequest": {
        "description": "Local login input.",
        "properties": {
          "email": {
            "description": "Account email.",
            "type": "string"
          },
          "mfa_code": {
            "description": "Six-digit TOTP or a single-use recovery code when MFA is enabled.",
            "type": [
              "string",
              "null"
            ]
          },
          "organization": {
            "description": "Organization slug.",
            "type": "string"
          },
          "password": {
            "description": "Account password.",
            "format": "password",
            "type": "string"
          }
        },
        "required": [
          "organization",
          "email",
          "password"
        ],
        "type": "object"
      },
      "ReadinessResponse": {
        "description": "Readiness document.",
        "properties": {
          "postgres": {
            "description": "PostgreSQL dependency state.",
            "type": "string"
          },
          "status": {
            "description": "Stable status.",
            "type": "string"
          }
        },
        "required": [
          "status",
          "postgres"
        ],
        "type": "object"
      },
      "RecoveryCodesResponse": {
        "description": "Recovery codes are returned exactly once.",
        "properties": {
          "codes": {
            "description": "Single-use codes. The operator must store these safely.",
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "codes"
        ],
        "type": "object"
      },
      "RecoveryCompleteRequest": {
        "description": "Complete recovery with a new password.",
        "properties": {
          "password": {
            "description": "Replacement password.",
            "format": "password",
            "type": "string"
          },
          "token": {
            "description": "URL-safe one-time token.",
            "type": "string"
          }
        },
        "required": [
          "token",
          "password"
        ],
        "type": "object"
      },
      "RecoveryStartRequest": {
        "description": "Begin recovery without revealing whether an identity exists.",
        "properties": {
          "email": {
            "description": "Account email.",
            "type": "string"
          },
          "organization": {
            "description": "Organization slug.",
            "type": "string"
          }
        },
        "required": [
          "organization",
          "email"
        ],
        "type": "object"
      },
      "RegisterRequest": {
        "description": "Local self-registration input.",
        "properties": {
          "display_name": {
            "description": "Public display name.",
            "type": "string"
          },
          "email": {
            "description": "Account email.",
            "type": "string"
          },
          "organization": {
            "description": "Organization slug to join.",
            "type": "string"
          },
          "password": {
            "description": "Account password (12–128 characters).",
            "format": "password",
            "type": "string"
          }
        },
        "required": [
          "organization",
          "display_name",
          "email",
          "password"
        ],
        "type": "object"
      },
      "SessionResponse": {
        "description": "Session bootstrap used by the Svelte client.",
        "properties": {
          "csrf_token": {
            "description": "CSRF value required in `x-csrf-token` on mutations.",
            "type": "string"
          },
          "expires_at": {
            "description": "Session expiry.",
            "format": "date-time",
            "type": "string"
          },
          "permissions": {
            "description": "Applicable permission keys.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "user": {
            "$ref": "#/components/schemas/UserResponse",
            "description": "Current account."
          }
        },
        "required": [
          "user",
          "csrf_token",
          "permissions",
          "expires_at"
        ],
        "type": "object"
      },
      "SessionSummaryResponse": {
        "description": "One active login session.",
        "properties": {
          "created_at": {
            "description": "Creation timestamp.",
            "format": "date-time",
            "type": "string"
          },
          "current": {
            "description": "Whether this is the calling session.",
            "type": "boolean"
          },
          "expires_at": {
            "description": "Expiry timestamp.",
            "format": "date-time",
            "type": "string"
          },
          "id": {
            "description": "Session ID.",
            "format": "uuid",
            "type": "string"
          },
          "last_seen_at": {
            "description": "Last request timestamp.",
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "current",
          "created_at",
          "last_seen_at",
          "expires_at"
        ],
        "type": "object"
      },
      "SetupRequest": {
        "description": "First organization and administrator input.",
        "properties": {
          "display_name": {
            "description": "Administrator display name.",
            "type": "string"
          },
          "email": {
            "description": "Administrator email.",
            "type": "string"
          },
          "organization_name": {
            "description": "Organization display name.",
            "type": "string"
          },
          "organization_slug": {
            "description": "URL-safe organization key.",
            "type": "string"
          },
          "password": {
            "description": "Administrator password (12–128 characters).",
            "format": "password",
            "type": "string"
          }
        },
        "required": [
          "organization_name",
          "organization_slug",
          "display_name",
          "email",
          "password"
        ],
        "type": "object"
      },
      "SetupStatusResponse": {
        "description": "First-run state.",
        "properties": {
          "required": {
            "description": "True when no user exists and setup can be completed.",
            "type": "boolean"
          }
        },
        "required": [
          "required"
        ],
        "type": "object"
      },
      "TokenRequest": {
        "description": "One opaque token input.",
        "properties": {
          "token": {
            "description": "URL-safe one-time token.",
            "type": "string"
          }
        },
        "required": [
          "token"
        ],
        "type": "object"
      },
      "TotpConfirmRequest": {
        "description": "TOTP setup proof.",
        "properties": {
          "code": {
            "description": "Current six-digit authenticator code.",
            "type": "string"
          }
        },
        "required": [
          "code"
        ],
        "type": "object"
      },
      "TotpEnrollmentResponse": {
        "description": "TOTP enrollment data for an authenticator application.",
        "properties": {
          "provisioning_uri": {
            "description": "Standard `otpauth://` provisioning URI.",
            "type": "string"
          },
          "secret": {
            "description": "Base32 secret for manual entry.",
            "type": "string"
          }
        },
        "required": [
          "secret",
          "provisioning_uri"
        ],
        "type": "object"
      },
      "UserResponse": {
        "description": "Safe account projection.",
        "properties": {
          "display_name": {
            "description": "Display name.",
            "type": "string"
          },
          "email": {
            "description": "Normalized email.",
            "type": "string"
          },
          "email_verified": {
            "description": "Email ownership state.",
            "type": "boolean"
          },
          "id": {
            "description": "User ID.",
            "format": "uuid",
            "type": "string"
          },
          "organization_id": {
            "description": "Organization ID.",
            "format": "uuid",
            "type": "string"
          }
        },
        "required": [
          "id",
          "organization_id",
          "display_name",
          "email",
          "email_verified"
        ],
        "type": "object"
      }
    }
  },
  "info": {
    "description": "Typed organizer, player, integration, and realtime API",
    "license": {
      "identifier": "LicenseRef-KCL-1.0",
      "name": "LicenseRef-KCL-1.0"
    },
    "title": "Kitsune API",
    "version": "0.1.0"
  },
